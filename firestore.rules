rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 1000)) &&
             data.avatar is string &&
             data.followers is number &&
             data.following is number &&
             data.adventures is number &&
             data.keys().hasAll(['uid', 'username', 'name', 'avatar', 'followers', 'following', 'adventures', 'updatedAt']);
    }

    function isValidBlogPost(data) {
      return data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.keys().hasAll(['authorId', 'title', 'content', 'date']);
    }

    function isValidSnapshot(data) {
      return data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.createdAt is number &&
             data.keys().hasAll(['userId', 'imageUrl', 'createdAt', 'type']);
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidBlogPost(incoming());
      allow update: if isOwner(existing().authorId) && isValidBlogPost(incoming());
      allow delete: if isOwner(existing().authorId);
    }

    match /snapshots/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidSnapshot(incoming());
      allow update: if isOwner(existing().userId) && isValidSnapshot(incoming());
      allow delete: if isOwner(existing().userId);
    }
  }
}
